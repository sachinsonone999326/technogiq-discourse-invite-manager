<Form @data={{this.initialData}} @onSubmit={{this.save}} as |form data|>

  {{#if this.successMessage}}
    <div class="alert alert-success">
      {{this.successMessage}}
      <br />
      
    </div>
  {{/if}}

  {{#if this.errorMessage}}
    <div class="alert alert-error">
      {{this.errorMessage}}
    </div>
  {{/if}}

  <form.Field
              @name="description"
              @title={{i18n "user.invited.invite.description"}}
              @format="large"
              @validation={{this.descriptionValidation}}
              as |field|
            >
     
       <field.Textarea maxlength="100" {{on "input" this.updateDescription}}/>
  </form.Field>
  <div class="description-counter">
    {{this.descriptionLength}} / 100
  </div>
  
  <form.Field
              @name="restrict_to"
              @title={{i18n "user.invited.invite.restrict"}}
              @format="large"
              
              as |field|
            >
              <field.Input
                placeholder={{i18n
                  "user.invited.invite.email_or_domain_placeholder"
                }}
              />
  </form.Field>

  <form.Field
                @name="max_uses"
                @title={{i18n "user.invited.invite.max_redemptions_allowed"}}
                @format="small"
                @validation="required"
                as |field|
              >
                <field.Input
                  @type="number"
                  min="1"
                  max="{{this.maxRedemptionsAllowedLimit}}"
                />
  </form.Field>

  <form.Field
                @name="expire_after"
                @title={{i18n "user.invited.invite.expires_after"}}
                @value=90
                @format="large"
                @validation="required"
                as |field|
              >
                <field.Select as |select|>
                  {{#each this.expireAfterOptions as |option|}}
                    <select.Option
                      @value={{option.id}}
                    >{{option.name}}</select.Option>
                  {{/each}}
                </field.Select>
  </form.Field>

  <form.Field
                @name="arrive_at_topic"
                @title={{i18n "user.invited.invite.invite_to_topic"}}
                @format="large"
                as |field|
              >
                <field.Input
                
              />
  </form.Field>


  <form.Field
                @name="add_to_groups"
                @title={{i18n "user.invited.invite.add_to_groups"}}
                @format="large"
                as |field|
              >
                <field.Input
                
              />
  </form.Field>

  <!-- IS EXPIRY DATE -->
  <form.Field
    @name="is_expiry_date"
    @title="Use Expiry Date"
    as |field|
  >
    <field.Checkbox />
  </form.Field>

  {{#if data.is_expiry_date}}
    <!-- EXPIRATION DATE -->
    <form.Field
      @name="expiration_date"
      @title="Membership Expiration Date"
      @validation="required"
      as |field|
    >
      <field.Input @type="date" />
    </form.Field>
  {{else}}
    <!-- PLAN TYPE -->

    <form.Container class="invite-metadata-row">
    

    <!-- MEMBERSHIP DURATION -->
    <form.Field
      @name="membership_duration_value"
      @title="Membership Duration"
      @validation="required"
      as |field|
    >
      <field.Input @type="number" min="1" />
    </form.Field>

      <form.Field
      @name="plan_type"
      @title="&nbsp;"
      @validation="required"
      as |field|
    >
      <field.Select as |select|>
       {{#each this.planTypeOptions as |option|}}
         <select.Option @value={{option.id}}>
          {{option.name}}
         </select.Option>
       {{/each}}
      </field.Select>
    </form.Field>

    </form.Container>
  {{/if}}

   
    
<form.Container class="invite-metadata-row">
    <!-- MEMBERSHIP DURATION -->
    <form.Field
      @name="renewal_period_value"
      @title="Allowed renewal period"
      @disabled={{not (eq data.renewal_period "monthly")}}
      
      @validation="required"
      as |field|
    >
      <field.Input @type="number" min="1" />
    </form.Field>

      <form.Field
      @name="renewal_period"
      @title="Renewal Period"
      @validation="required"
      as |field|
    >
      <field.Select  {{on "change" (fn this.renewalPeriodChanged form data)}} as |select|>
       {{#each this.renewalPeriodOptions as |option|}}
         <select.Option @value={{option.id}}>
          {{option.name}}
         </select.Option>
       {{/each}}
      </field.Select>
    </form.Field>
  </form.Container>

   
<form.Field
    @name="is_batch_mode"
    @title="Use Batch Mode"
    as |field|
  >
    <field.Checkbox />
  </form.Field>
  
{{#if data.is_batch_mode}}
  <form.Field
      @name="number_of_invitations"
      @title="Number of Invitations"
      @validation="required"
      as |field|
    >
      <field.Input @type="number" min="1" />
    </form.Field>

  {{/if}}

  <!-- METADATA JSON -->
  

  <form.Section @title="Metadata">
    <form.Container>
      <form.Button
        @label="Add_metadata"
        @action={{fn this.addMetadata2}}
      />
    </form.Container>

    
     {{#each this.localMetadata as |pair index|}}
      <form.Container class="invite-metadata-row">
        <input
          type="text"
          class="input"
          placeholder="Key"
          
          value={{pair.key}}
          {{on "input" (fn this.updateMetadata2  index "key")}}
        />

        

        <textarea
         class="input"
         rows="1"
         {{on "input" (fn this.updateMetadata2 index "value")}}
        >{{pair.value}}</textarea>

       

        <form.Button
          class="btn-danger"
          @label="Remove"
          @action={{fn this.removeMetadata2  index}}
        />
      </form.Container>
    {{/each}}
  </form.Section>

  <form.Actions>
    <form.Submit @disabled={{this.isSaving}} />
  </form.Actions>
<style>
textarea{resize: vertical;}
.invite-metadata-row .form-kit__container-content
{
  width: auto;
}

.description-wrapper {
  position: relative;
  display: inline-block;
  width: 100%;
}

.description-wrapper textarea {
  width: 100%;
  padding-bottom: 24px; /* Prevent text from overlapping the counter */
  resize: vertical;
  box-sizing: border-box;
}

.description-counter {
  
  bottom: 8px;
  right: 10px;
  font-size: 12px;
  
  background: var(--secondary);
  
  pointer-events: none;
  line-height: 1;
}

#control-is_expiry_date label.form-kit__container-title{
  display:none;
}
#control-is_expiry_date label.form-kit__control-checkbox-label span{
 font-weight: 600;
 }

 #control-is_batch_mode label.form-kit__container-title{
  display:none;
}
#control-is_batch_mode label.form-kit__control-checkbox-label span{
 font-weight: 600;
 }
</style>
</Form>
