{{#if this.loading}}
  <p>Loading users…</p>
{{else}}
<header class="invite-header">
  <div class="search">

    <svg
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      aria-hidden="true"
    >

      <path
        d="M21 21l-4.35-4.35"
        stroke="#9ca3af"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />

      <circle
        cx="11"
        cy="11"
        r="6"
        stroke="#9ca3af"
        stroke-width="2"
      />

    </svg>

    <Input
      @type="text"
      @value={{this.searchTerm}}
      placeholder="Search requests, description, username, email, urls"
      aria-label="Search requests"
    />

  </div>

</header>
  <table class="invite-grid">
    <thead>
      <tr>
        <th>Request</th>
        <th>Registration date</th>
        <th>Description</th>
        <th>Username</th>
        <th>Email</th>
        <th>Invite URL</th>
        <th>Expiry Date</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      {{#each this.filteredInvites as |invite|}}
        <tr>
          <td>{{invite.batch_id}}</td>
          <td>{{this.formatInviteDate invite.registration_date}}</td>
          <td>

            
            {{#if invite.description}}
                {{invite.description}}
            {{else}}
                -
            {{/if}}

          </td>
          <td>{{invite.username}}</td>
          <td>{{invite.email}}</td>
          <td class="mono">{{this.baseUrl}}/invites/{{invite.invite_key}}</td>
          <td>{{this.formatInviteDateWithoutTime invite.expiration_date}}</td>
          <td class="actions">
          
           <DMenu
      @identifier="view-invites-menu"
      @icon="ellipsis"
      class="btn-flat more-button"
      @autofocus={{true}}
    >
      <DropdownMenu as |dropdown|>
        <dropdown.item>
          <DButton
            @action={{this.ExtendMembership invite}}
            @label="extend_membership"
            class="btn-transparent unassign-btn"
          />
        </dropdown.item>
        <dropdown.item>
          <DButton
            @action={{this.EditMetadata invite}}
            @label="edit_metadata"
            class="btn-transparent edit-assignment-btn"
          />
        </dropdown.item>
      </DropdownMenu>
    </DMenu>
           </td>
        </tr>
      {{/each}}
    </tbody>
  </table>

  <!--<div class="pagination-controls">
    <button
      class="btn"
      disabled={{eq this.page 1}}
      {{on "click" this.prevPage}}
    >
      ◀ Prev
    </button>

    <span>
      Page {{this.page}} of {{this.totalPages}}
    </span>

    <button
      class="btn"
      disabled={{eq this.page this.totalPages}}
      {{on "click" this.nextPage}}
    >
      Next ▶
    </button>
  </div>-->
{{/if}}

<style>
.mono {
    font-family: monospace;
    background: #fbfdff;
    padding: 6px;
    border-radius: 6px;
    border: 1px solid var(--border);
    display: inline-block;
    word-break: break-all;
}

.search {
  margin-left: auto;
  display: block;
  align-items: center;
  gap: 8px;
  border-radius: 10px;
  padding: 8px 12px;
  min-width: 320px;
}

.search input {
  background: transparent;
  outline: none;
  width: 100%;
  font-size: 14px;
}

.segmented{display:flex;border:1px solid var(--border);border-radius:8px;overflow:hidden;font-size: 12px;}
  .segmented button{border:0;padding:13px 19px;background:transparent;cursor:pointer;font-weight:600;color:var(--muted)}
  .search{margin-left:auto;display:auto;align-items:center;gap:8px;text-align:right}
  .search input{padding:8px 10px;border-radius:8px;width:350px; margin-bottom:0}
</style>
