<template>
    <DModal
      @title="Invite details — request #{{model.id}}"
      @closeModal={{@closeModal}}
      @inline={{@inline}}
      class=""
    >
     <:body>
    
<div class="invite-details-modal">

      <div class="card">
        <h3>Invitation Details — Read-Only</h3>

        <!-- Basic Information -->
        <div class="section">
          <div class="section-header">Basic information</div>
          <div class="section-body">

            <div class="row">
              <div class="label">Description</div>
              <div class="value">{{this.model.description}}</div>
            </div>

            <div class="row">
              <div class="label">Restrict to</div>
              <div class="value">{{this.inviteDetails.invite.domain}}{{this.inviteDetails.invite.email}}</div>
            </div>

            <div class="row">
              <div class="label">Max uses</div>
              <div class="value">{{this.inviteDetails.invite.max_redemptions_allowed}}</div>
            </div>

            <div class="row">
              <div class="label">Expire after</div>
              <div class="value">{{this.formatInviteDate this.inviteDetails.invite.expires_at}}</div>
            </div>

            <div class="row">
              <div class="label">Arrive at topic</div>
              <div class="value">
                {{#each this.inviteDetails.topics as |topic|}}
                 
                      {{topic.title}}, 
                 
                {{/each}}

              </div>
            </div>

            <div class="row">
              <div class="label">Add to groups</div>
              <div class="value">

               {{#each this.inviteDetails.groups as |group|}}
                  
                      {{group.name}}, 
                 
                {{/each}}

            </div>
            </div>

          </div>
        </div>

        <!-- Membership -->
        <div class="section">
          <div class="section-header">Membership rules</div>
          <div class="section-body">

            <div class="row">
              <div class="label">Membership expiration date</div>
              <div class="value">
                    {{#if @model.metadata.is_expiry_date}}
                                 {{this.formatInviteDateWithoutTime @model.metadata.expiration_date}}
                    {{else}}
                        -
                   {{/if}}
             </div>
            </div>

            <div class="row">
              <div class="label">Membership duration</div>
              <div class="value">{{model.metadata.membership_duration_value}} {{model.metadata.plan_type}}</div>
            </div>

            <div class="row">
              <div class="label">Allowed renewal period</div>
              <div class="value">{{model.metadata.renewal_period}} - {{model.metadata.renewal_period_value}}</div>
            </div>

          </div>
        </div>

        <!-- Batch Mode -->
        <div class="section">
          <div class="section-header">Batch mode</div>
          <div class="section-body">
            <div class="row">
              <div class="label">Status</div>
              <div class="value">{{#if @model.metadata.is_batch_mode}}
                      Enabled - {{@model.metadata.number_of_invitations}} invitations
                      {{else}}
                       Disabled
               {{/if}}</div>
            </div>
          </div>
        </div>

        <!-- Metadata -->
        <div class="section">
          <div class="section-header">Metadata (key → value)</div>
          <div class="section-body">

            <table class="meta-table">
              <tbody>
                {{#each this.metadataList as |meta|}}
                  <tr>
                    <td class="key">{{meta.key}}</td>
                    <td>
                      <code class="json">{{meta.value}}</code>
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>

          </div>
        </div>

      </div>

    </div>
    <style>.invite-details-modal .card {
  padding: 16px;
}

.section {
  margin-bottom: 20px;
}

.section-header {
  font-weight: bold;
  margin-bottom: 10px;
  border-bottom: 1px solid #ddd;
  padding-bottom: 5px;
}

.row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}

.label {
  font-weight: 600;
}

.value {
  text-align: left;
}

.meta-table {
  width: 100%;
}

.meta-table td {
  padding: 6px;
  vertical-align: top;
}

.json {
  background: #f5f5f5;
  padding: 4px;
  display: block;
}
.row {
  display: flex;
  gap: 16px;
  margin-bottom: 10px;
  align-items: flex-start;
}

.label {
  width: 240px;
  font-weight: 700;
  font-size: 14px;
}

.value {
  flex: 1;
  background: #fafafa;
#  border: 1px solid var(--border);
#  padding: 10px;
  border-radius: 6px;
  font-size: 14px;
#  color: var(--muted);
#  white-space: pre-wrap;
}

</style>
     </:body>
  <:footer>
    <DButton
      @label="Close"
      @action={{@closeModal}}
      class="btn-primary"
    />
  </:footer>
 </DModal>
</template>
