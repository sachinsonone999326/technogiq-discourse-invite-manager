<template>
    <DModal
      @title=""
      @closeModal={{@closeModal}}
      @inline={{@inline}}
      class={{if this.isMaximized "fullscreen-modal"}}
    >

    <:aboveHeader></:aboveHeader>
          <:headerAboveTitle></:headerAboveTitle>
          <:headerBelowTitle>
          <div><h2>Invite details — request #{{model.id}}</h2></div>
          <DButton
          @icon={{if this.isMaximized "compress" "expand"}}
          @action={{this.toggleMaximize}}
          class="btn-flat btn-transparent modal-close"
        /></:headerBelowTitle>
          <:belowHeader></:belowHeader>


     <:body>
    
<div class="invite-details-modal">
      
      <div class="card">
        <h3>Invitation Details — Read-Only</h3>

        <!-- Basic Information -->
        <div class="section">
          <div class="section-header">Basic information</div>
          <div class="section-body">

            <div class="row">
              <div class="label">Description</div>
              <div class="value">
                {{#if this.model.description}}
                {{this.model.description}}
                {{else}}
                  -
                {{/if}}
              </div>
            </div>

            <div class="row">
              <div class="label">Restrict to</div>
              <div class="value">

              {{if (or this.inviteDetails.invite.domain this.inviteDetails.invite.email)
                (concat this.inviteDetails.invite.domain this.inviteDetails.invite.email)
                "-"
              }}

              </div>
            </div>

            <div class="row">
              <div class="label">Max uses</div>
              <div class="value">{{this.inviteDetails.invite.max_redemptions_allowed}}</div>
            </div>

            <div class="row">
              <div class="label">Expire after</div>
              <div class="value">{{this.formatInviteDate this.inviteDetails.invite.expires_at}}</div>
            </div>

            <div class="row">
              <div class="label">Arrive at topic</div>
              <div class="value">
                
                 {{#if this.topicNames}}
                  {{this.topicNames}}
                {{else}}
                  -
                {{/if}}
              </div>
            </div>

            <div class="row">
              <div class="label">Add to groups</div>
              <div class="value">

                {{#if this.groupNames}}
                  {{this.groupNames}}
                {{else}}
                  -
                {{/if}}
            </div>
            </div>

          </div>
        </div>

        <!-- Membership -->
        <div class="section">
          <div class="section-header">Membership rules</div>
          <div class="section-body">

            <div class="row">
              <div class="label">Membership expiration date</div>
              <div class="value">
                    {{#if this.inviteDetails.invite.is_expiry_date}}
                                 {{this.formatInviteDateWithoutTime this.inviteDetails.invite.expiration_date}}
                    {{else}}
                        -
                   {{/if}}
             </div>
            </div>

            <div class="row">
              <div class="label">Membership duration</div>
              <div class="value">
             {{#if this.inviteDetails.invite.is_expiry_date}} 
                 -
             {{else}}
              {{this.inviteDetails.invite.membership_duration_value}} {{this.inviteDetails.invite.plan_type}}
              {{/if}}
              </div>
            </div>

            <div class="row">
              <div class="label">Allowed renewal period</div>
              <div class="value">{{this.inviteDetails.invite.renewal_period}} - {{this.inviteDetails.invite.renewal_period_value}}</div>
            </div>

          </div>
        </div>

        <!-- Batch Mode -->
        <div class="section">
          <div class="section-header">Batch mode</div>
          <div class="section-body">
            <div class="row">
              <div class="label">Status</div>
             <div class="value">
                {{#if (eq this.inviteDetails.status "Enabled")}}
                  Enabled - {{this.inviteDetails.total_user_remaining_invites}} invitations
                {{else}}
                  Disabled
                {{/if}}
              </div>
            </div>

            <div class="row">
              <div class="label">Total Invitations</div>
              <div class="value">{{this.inviteDetails.invite.number_of_invitations}} invitations
                </div>
            </div>
          </div>
        </div>

        <!-- Metadata -->
        <div class="section">
          <div class="section-header">Metadata (key → value)</div>
          <div class="section-body">

            
              
                {{#each this.metadataList as |meta|}}
                <div class="row">
                  <div class="label">{{meta.key}}</div>
                   <div class="value">
                      <code class="json">{{meta.value}}</code>
                    </div>
                   </div>
                {{/each}}
              
           

          </div>
        </div>

      </div>

    </div>
    <style>.invite-details-modal .card {
  padding: 16px;
}

.section {
  margin-bottom: 20px;
}

.section-header {
  font-weight: bold;
  margin-bottom: 10px;
  border-bottom: 1px solid #ddd;
  padding-bottom: 5px;
}

div.invite-details-modal .row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 6px;
}

.label {
  font-weight: 600;
}

.value {
  text-align: left;
}

.meta-table {
  width: 100%;
}

.meta-table td {
  padding: 6px;
  vertical-align: top;
}

.json {
  background: #f5f5f5;
  padding: 4px;
  display: block;
}
div.invite-details-modal .row {
  display: flex;
  gap: 16px;
  margin-bottom: 10px;
  align-items: flex-start;
}

.label {
  width: 240px;
  font-weight: 700;
  font-size: 14px;
}

.value {
  flex: 1;
  background: #fafafa;
#  border: 1px solid var(--border);
#  padding: 10px;
  border-radius: 6px;
  font-size: 14px;
#  color: var(--muted);
#  white-space: pre-wrap;
}

.fullscreen-modal {
  width: 98vw !important;
  max-width: 98vw !important;
  height: 95vh !important;

          --modal-max-width: 98vw !important;
        --modal-width: 98vw !important;
        --modal-min-width: 98vw !important;
}

.modal-header-custom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.d-modal__header{
  justify-content: end!imporant;
}

.d-modal__header > div:first-child

 {
    flex: 1;
}

</style>
     </:body>
  <:footer>
    <DButton
      @label="Close"
      @action={{@closeModal}}
      class="btn-primary"
    />

  </:footer>
 </DModal>
</template>
